NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/redcart
JWT_SECRET=change-this-to-a-very-long-secret
JWT_EXPIRES_IN=2h
CLIENT_URL=http://localhost:5173
DB_STARTUP_MAX_RETRIES=12
DB_STARTUP_RETRY_MS=3000
# Multiple origins are supported as comma-separated values.
# Example: CLIENT_URL=https://redcart-frontend.vercel.app,https://redcart-frontend-git-main.vercel.app
# Wildcard origins are supported (for preview deployments), e.g. https://redcart-frontend-*.vercel.app
# Render production example:
# NODE_ENV=production
# CLIENT_URL=https://redcart-frontend.vercel.app,https://redcart-frontend-git-main-yourteam.vercel.app
PRISMA_CLIENT_ENGINE_TYPE=library
MPESA_ENABLED=false
MPESA_ENV=sandbox
# Optional override. If blank, base URL is derived from MPESA_ENV.
MPESA_BASE_URL=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Optional callback base override.
# In hosted production (Render/Railway/Fly), callback URL is auto-derived from the incoming request host.
# Set this only if you want to force a specific public HTTPS domain.
MPESA_CALLBACK_BASE_URL=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
# Force IPv4 lookup for SMTP host (recommended on Render to avoid IPv6 ENETUNREACH).
SMTP_FORCE_IPV4=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Email transport provider. Use `smtp` locally; prefer `resend` on Render Free (SMTP ports are blocked).
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
# Optional sender override for Resend. Falls back to SMTP_FROM when blank.
RESEND_FROM=
# Optional API base URL override.
RESEND_API_BASE_URL=
