NODE_ENV=production
DATABASE_URL=postgresql://redcart_database_6brs_user:ndWVsVEu07s2PmIjNnw7ymImoFCzqjYJ@dpg-d6hll3fkijhs73fj5c0g-a.oregon-postgres.render.com/redcart_database_6brs?sslmode=require
JWT_SECRET=change-this-to-a-very-long-secret
JWT_EXPIRES_IN=2h
CLIENT_URL=https://your-frontend.vercel.app,https://your-frontend-git-main-yourteam.vercel.app
DB_STARTUP_MAX_RETRIES=12
DB_STARTUP_RETRY_MS=3000
PRISMA_CLIENT_ENGINE_TYPE=library

MPESA_ENABLED=false
MPESA_ENV=sandbox
MPESA_BASE_URL=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Optional in hosted runtime; leave blank to auto-use Render request host.
# Set only if you need to force a different public HTTPS callback domain.
MPESA_CALLBACK_BASE_URL=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
# Recommended true on Render to avoid IPv6 SMTP routing issues.
SMTP_FORCE_IPV4=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Render Free blocks SMTP ports; use Resend API delivery instead.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
# Must be a verified sender/domain in Resend (e.g. onboarding@resend.dev for testing).
RESEND_FROM=
RESEND_API_BASE_URL=
